# ============================================================
# Environment variables for Fintech Agent
# Copy this file to .env and fill in values
# WARNING: NEVER commit .env — it contains secrets!
# ============================================================

# --- LLM Provider ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# --- LLM Toggle ---
# true  = use regex/mock extractor (no API key needed, default)
# false = use real OpenAI API (requires OPENAI_API_KEY)
MOCK_LLM=true
LLM_TIMEOUT=30

# --- App Settings ---
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- Logging ---
LOG_LEVEL=INFO
